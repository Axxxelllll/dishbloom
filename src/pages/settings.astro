---
export const prerender = false;
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import { env } from "cloudflare:workers";

const db = env.DB;
const cookieHeader = Astro.request.headers.get("cookie") || "";
const tokenMatch = cookieHeader.match(/db_token=([^;]+)/);
let user: any = null;

if (!tokenMatch) return Astro.redirect("/login");
try {
  const decoded = JSON.parse(atob(tokenMatch[1]));
  if (decoded.exp < Date.now()) return Astro.redirect("/login");
  user = await db.prepare("SELECT * FROM users WHERE id = ?").bind(decoded.id).first();
  if (!user) return Astro.redirect("/login");
} catch { return Astro.redirect("/login"); }
---
<Base title="Settings | DishBloom">
  <Navbar />
  <section class="settings-page">
    <div class="settings-card">
      <h1>Account settings</h1>

      <div class="settings-form">
        <label class="settings-label">Display name
          <input type="text" id="name" value={user.display_name || ""} class="auth-input" />
        </label>
        <label class="settings-label">Username
          <input type="text" id="username" value={user.username || ""} class="auth-input" disabled />
          <span class="input-hint">Cannot be changed</span>
        </label>
        <label class="settings-label">Email
          <input type="email" id="email" value={user.email || ""} class="auth-input" disabled />
          <span class="input-hint">Cannot be changed</span>
        </label>
        <label class="settings-label">Bio
          <textarea id="bio" class="auth-input" rows="3" placeholder="Tell us about yourself...">{user.bio || ""}</textarea>
        </label>

        <p class="auth-error" id="error" style="display:none"></p>
        <p class="auth-success" id="success" style="display:none"></p>
        <button class="auth-btn" id="save-btn">Save changes</button>
      </div>

      <hr class="settings-divider" />

      <div class="danger-zone">
        <h3>Danger zone</h3>
        <button class="danger-btn" id="logout-btn">Log out</button>
      </div>
    </div>
  </section>
</Base>

<style>
.settings-page { display: flex; justify-content: center; padding: 40px 20px; }
.settings-card { width: 100%; max-width: 500px; background: var(--white); border: 1px solid var(--border); border-radius: 16px; padding: 40px 32px; }
.settings-card h1 { font-size: 1.6rem; margin-bottom: 24px; }
.settings-form { display: flex; flex-direction: column; gap: 16px; }
.settings-label { display: flex; flex-direction: column; gap: 4px; font-size: 0.85rem; font-weight: 500; color: var(--text-light); }
.auth-input { padding: 12px 16px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 0.95rem; outline: none; font-family: inherit; }
.auth-input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px var(--gold-light); }
.auth-input:disabled { background: var(--bg); color: var(--text-lighter); cursor: not-allowed; }
.input-hint { font-size: 0.75rem; color: var(--text-lighter); }
.auth-btn { padding: 12px; border-radius: var(--radius); border: none; background: var(--gold); color: white; font-weight: 600; font-size: 0.95rem; cursor: pointer; margin-top: 4px; }
.auth-btn:hover { background: var(--gold-dark); }
.auth-error { color: #D64545; font-size: 0.85rem; }
.auth-success { color: #2D8B4E; font-size: 0.85rem; }
.settings-divider { border: none; border-top: 1px solid var(--border-light); margin: 28px 0; }
.danger-zone h3 { font-size: 1rem; font-family: 'Inter', sans-serif; margin-bottom: 12px; }
.danger-btn { padding: 10px 20px; border-radius: var(--radius); border: 1px solid #D64545; background: transparent; color: #D64545; font-weight: 600; font-size: 0.88rem; cursor: pointer; }
.danger-btn:hover { background: #FEF0F0; }
</style>

<script>
document.getElementById("save-btn")?.addEventListener("click", async () => {
  const name = (document.getElementById("name") as HTMLInputElement).value;
  const bio = (document.getElementById("bio") as HTMLTextAreaElement).value;
  const error = document.getElementById("error")!;
  const success = document.getElementById("success")!;
  const btn = document.getElementById("save-btn") as HTMLButtonElement;

  error.style.display = "none";
  success.style.display = "none";
  btn.textContent = "Saving...";
  btn.disabled = true;

  try {
    const res = await fetch("/api/update-profile", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ name, bio }),
    });
    const data = await res.json();
    if (!res.ok) {
      error.textContent = data.error;
      error.style.display = "block";
    } else {
      success.textContent = "Settings saved!";
      success.style.display = "block";
    }
  } catch(e) {
    error.textContent = "Something went wrong";
    error.style.display = "block";
  }
  btn.textContent = "Save changes";
  btn.disabled = false;
});

document.getElementById("logout-btn")?.addEventListener("click", () => {
  document.cookie = "db_token=; Path=/; Max-Age=0";
  localStorage.removeItem("db_user");
  window.location.href = "/";
});
</script>
