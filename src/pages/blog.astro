---
export const prerender = false;
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import AdSlot from '../components/AdSlot.astro';
import { env } from "cloudflare:workers";

const db = env.DB;
const { results: recipes } = await db.prepare(
  "SELECT title, slug, description, hero_image, cuisine, total_time, calories, category, created_at FROM recipes WHERE hero_image IS NOT NULL AND hero_image != '' ORDER BY id DESC LIMIT 30"
).all();
---
<Base title="Blog | DishBloom" description="Tips, guides, and stories from the DishBloom kitchen. Learn to cook with confidence.">
  <Navbar />

  <section class="blog-hero-section">
    <div class="container">
      <h1>DishBloom Blog</h1>
      <p class="blog-hero-sub">Tips, techniques, and the stories behind our favorite recipes</p>
    </div>
  </section>

  <AdSlot id="ad-blog-index-top" size="leaderboard" />

  <div class="blog-grid container">
    {recipes.map((r, i) => (
      <a href={"/blog/" + r.slug} class={"blog-card" + (i === 0 ? " blog-card-featured" : "")}>
        <img src={r.hero_image} alt={r.title} loading="lazy" />
        <div class="blog-card-body">
          <span class="blog-card-cat">{r.cuisine || r.category}</span>
          <h2 class="blog-card-title">How to Make the Perfect {r.title}</h2>
          <p class="blog-card-desc">{r.description?.substring(0, 120)}...</p>
          <div class="blog-card-meta">
            <span>{r.total_time} min</span>
            <span>&middot;</span>
            <span>{r.calories} cal</span>
          </div>
        </div>
      </a>
    ))}
  </div>

  <AdSlot id="ad-blog-index-bottom" size="leaderboard" />
</Base>

<style>
.blog-hero-section { text-align: center; padding: 48px 0 24px; }
.blog-hero-section h1 { font-size: clamp(2rem, 5vw, 3rem); }
.blog-hero-sub { color: var(--text-light); font-size: 1rem; margin-top: 6px; }
.blog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; padding: 32px 20px 60px; }
.blog-card { background: var(--white); border-radius: 16px; overflow: hidden; box-shadow: var(--shadow); transition: transform 0.2s; }
.blog-card:hover { transform: translateY(-4px); }
.blog-card-featured { grid-column: 1 / -1; display: grid; grid-template-columns: 1fr 1fr; }
.blog-card img { width: 100%; height: 220px; object-fit: cover; }
.blog-card-featured img { height: 100%; min-height: 300px; }
.blog-card-body { padding: 20px; }
.blog-card-cat { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; color: var(--gold-dark); letter-spacing: 0.5px; }
.blog-card-title { font-size: 1.2rem; margin: 8px 0; line-height: 1.3; }
.blog-card-featured .blog-card-title { font-size: 1.5rem; }
.blog-card-desc { font-size: 0.88rem; color: var(--text-light); line-height: 1.5; margin-bottom: 12px; }
.blog-card-meta { font-size: 0.78rem; color: var(--text-lighter); display: flex; gap: 6px; }
@media (max-width: 768px) {
  .blog-card-featured { grid-template-columns: 1fr; }
  .blog-card-featured img { height: 220px; }
  .blog-grid { grid-template-columns: 1fr; }
}
</style>
