---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import AdSlot from '../../components/AdSlot.astro';
import CommunityBanner from '../../components/CommunityBanner.astro';

const { slug } = Astro.params;
import { env } from "cloudflare:workers";
const db = env.DB;

const recipe = await db.prepare("SELECT * FROM recipes WHERE slug = ?").bind(slug).first();
if (!recipe) return Astro.redirect("/404");

const ingredients = JSON.parse(recipe.ingredients || "[]");
const steps = JSON.parse(recipe.steps || "[]");
const substitutions = JSON.parse(recipe.substitutions || "[]");
const commonMistakes = JSON.parse(recipe.common_mistakes || "[]");
const tags = JSON.parse(recipe.tags || "[]");
const dietary = JSON.parse(recipe.dietary || "[]");
const groups = [...new Set(ingredients.map((i: any) => i.group))];
const heroImg = recipe.hero_image || "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=900&q=85";
---
<Base title={recipe.title + " | DishBloom"} description={recipe.description}>
  <CommunityBanner />
  <Navbar />
  
  <article class="recipe-page">
    <div class="recipe-hero">
      <img src={heroImg} alt={recipe.title} class="hero-img" />
      <div class="hero-overlay">
        <div class="hero-tags">
          {dietary.map((d: string) => <span class="hero-tag">{d.replace("-", " ")}</span>)}
        </div>
      </div>
    </div>

    <AdSlot id="ad-below-recipe-hero" size="leaderboard" />

    <div class="recipe-content" data-steps={JSON.stringify(steps)} data-category={recipe.category} data-cuisine={recipe.cuisine}>
      <header class="recipe-header">
        <div class="recipe-breadcrumb">
          <a href="/">Home</a> <span>/</span> <span>{recipe.title}</span>
        </div>
        <h1 class="recipe-title">{recipe.title}</h1>
        <p class="recipe-desc">{recipe.description}</p>
        
        <div class="recipe-meta-bar">
          <div class="meta-item"><span class="meta-icon">&#9733;</span><span class="meta-val">{recipe.avg_rating || "4.5"}</span></div>
          <div class="meta-item"><span class="meta-icon">&#9202;</span><span class="meta-val">{recipe.total_time} min</span></div>
          <div class="meta-item"><span class="meta-icon">&#127860;</span><span class="meta-val">{recipe.servings} servings</span></div>
          <div class="meta-item"><span class="meta-icon">&#128293;</span><span class="meta-val">{recipe.calories} cal</span></div>
          <div class="meta-item"><span class="meta-icon">&#128278;</span><span class="meta-val">{recipe.difficulty}</span></div>
        </div>

        <div class="recipe-actions">
          <button class="action-btn action-save" id="save-btn" data-recipe-id={recipe.id}>&#9829; Save ({recipe.total_saves || 0})</button>
          <button class="action-btn action-print" onclick="window.print()">&#128424; Print</button>
          <a href="#recipe-steps" class="action-btn action-jump">&#11015; Jump to recipe</a>
        </div>
      </header>

      {recipe.quick_summary && (
        <section class="quick-summary">
          <div class="qs-badge">30 second summary</div>
          <p>{recipe.quick_summary}</p>
        </section>
      )}

      <AdSlot id="ad-before-nutrition" size="rectangle" />

      <section class="nutrition-card">
        <h3>Nutrition per serving</h3>
        <div class="nutrition-grid">
          <div class="nut-item"><span class="nut-val">{recipe.calories}</span><span class="nut-label">Calories</span></div>
          <div class="nut-item"><span class="nut-val">{recipe.protein}g</span><span class="nut-label">Protein</span></div>
          <div class="nut-item"><span class="nut-val">{recipe.carbs}g</span><span class="nut-label">Carbs</span></div>
          <div class="nut-item"><span class="nut-val">{recipe.fat}g</span><span class="nut-label">Fat</span></div>
          <div class="nut-item"><span class="nut-val">{recipe.fiber}g</span><span class="nut-label">Fiber</span></div>
        </div>
      </section>

      <section class="ingredients-section" id="ingredients">
        <div class="ing-header">
          <h2>Ingredients</h2>
          <div class="servings-control">
            <button class="srv-btn" data-action="decrease">-</button>
            <span class="srv-val" id="servings-display">{recipe.servings}</span>
            <button class="srv-btn" data-action="increase">+</button>
            <span class="srv-label">servings</span>
          </div>
        </div>
        {groups.map((group: string) => (
          <div class="ing-group">
            <h4 class="ing-group-title">{group}</h4>
            {ingredients.filter((i: any) => i.group === group).map((ing: any) => (
              <label class="ing-row">
                <input type="checkbox" class="ing-check" />
                <span class="ing-amount" data-base={ing.amount}>{ing.amount}</span>
                <span class="ing-unit">{ing.unit}</span>
                <span class="ing-item">{ing.item}</span>
              </label>
            ))}
          </div>
          
        ))}
      </section>

      <AdSlot id="ad-before-steps" size="rectangle" />

      <section class="steps-section" id="recipe-steps">
        <h2>Instructions</h2>
        {steps.flatMap((step: any, idx: number) => [
          idx > 0 && idx % 3 === 0 && <AdSlot id={"ad-step-" + idx} size="rectangle" />,
          (
          <div class="step-card">
            <div class="step-num">{idx + 1}</div>
            <div class="step-content">
              <h3 class="step-title">{step.title}</h3>
              <p class="step-text">{step.text}</p>
              {step.timer > 0 && (
                <button class="timer-btn" data-seconds={step.timer}>
                  &#9202; Start timer ({Math.floor(step.timer / 60)}:{String(step.timer % 60).padStart(2, "0")})
                </button>
              )}
            </div>
          </div>
        )]).filter(Boolean)}
      </section>

      {substitutions.length > 0 && (
        <section class="subs-section">
          <h2>Substitutions</h2>
          <div class="subs-grid">
            {substitutions.map((sub: any) => (
              <div class="sub-card">
                <span class="sub-original">{sub.original}</span>
                <span class="sub-arrow">&#8594;</span>
                <span class="sub-swap">{sub.swap}</span>
              </div>
            ))}
          </div>
        </section>
      )}

      {commonMistakes.length > 0 && (
        <section class="mistakes-section">
          <h2>Common mistakes</h2>
          <div class="mistakes-list">
            {commonMistakes.map((m: string) => (
              <div class="mistake-item">
                <span class="mistake-icon">&#9888;</span>
                <span>{m}</span>
              </div>
            ))}
          </div>
        </section>
      )}

      <AdSlot id="ad-after-recipe" size="leaderboard" />

      <section class="made-this-section">
        <h2>I made this!</h2>
        <p class="made-this-desc">Cooked this recipe? Share your photo and inspire others.</p>
        <button class="made-this-btn">&#128247; Upload your photo</button>
      </section>

      <section class="tags-section">
        <div class="tags-wrap">
          {tags.map((tag: string) => (
            <a href="#" class="recipe-tag">#{tag}</a>
          ))}
        </div>
      </section>
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Recipe",
    "name": recipe.title,
    "description": recipe.description,
    "image": recipe.hero_image || "",
    "author": { "@type": "Organization", "name": "DishBloom" },
    "datePublished": recipe.created_at || "2026-06-28",
    "prepTime": "PT" + (recipe.prep_time || 0) + "M",
    "cookTime": "PT" + (recipe.cook_time || 0) + "M",
    "totalTime": "PT" + (recipe.total_time || 0) + "M",
    "recipeYield": String(recipe.servings || 4) + " servings",
    "recipeCategory": recipe.category || "Main Course",
    "recipeCuisine": recipe.cuisine || "",
    "nutrition": {
      "@type": "NutritionInformation",
      "calories": (recipe.calories || 0) + " calories",
      "proteinContent": (recipe.protein || 0) + " g",
      "carbohydrateContent": (recipe.carbs || 0) + " g",
      "fatContent": (recipe.fat || 0) + " g",
      "fiberContent": (recipe.fiber || 0) + " g"
    },
    "recipeIngredient": ingredients.map((i: any) => (i.amount || "") + " " + (i.unit || "") + " " + i.item),
    "recipeInstructions": steps.map((s: any) => ({ "@type": "HowToStep", "name": s.title, "text": s.text })),
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": recipe.avg_rating || 4.5,
      "ratingCount": recipe.review_count || 12,
      "bestRating": "5",
      "worstRating": "1"
    },
    "keywords": tags.join(", ")
  })} />
  
      <section class="related-section">
        <h2>More like this</h2>
        <div class="related-grid" id="related-grid"></div>
      </section>

      <section class="reviews-section">
        <h2>Reviews</h2>
        <div class="review-form" id="review-form">
          <div class="star-picker" id="star-picker">
            <span class="star" data-val="1">&#9733;</span>
            <span class="star" data-val="2">&#9733;</span>
            <span class="star" data-val="3">&#9733;</span>
            <span class="star" data-val="4">&#9733;</span>
            <span class="star" data-val="5">&#9733;</span>
          </div>
          <textarea id="review-text" placeholder="Share your thoughts on this recipe..." rows="3" style="width:100%;padding:12px;border:1px solid var(--border);border-radius:var(--radius);font-family:inherit;resize:vertical;"></textarea>
          <button class="action-btn" id="submit-review" style="margin-top:8px">Submit review</button>
        </div>
        <div id="reviews-list"></div>
      </section>

      <section class="made-section">
        <h2>I made this!</h2>
        <div class="made-form">
          <input type="text" id="made-note" placeholder="How did it turn out? Any tips?" style="width:100%;padding:12px;border:1px solid var(--border);border-radius:var(--radius);" />
          <button class="action-btn" id="made-btn" style="margin-top:8px">Share that I made this</button>
        </div>
        <div id="made-list"></div>
      </section>

<style>
.related-section, .reviews-section, .made-section { margin-top: 40px; }
.related-section h2, .reviews-section h2, .made-section h2 { font-size: 1.4rem; margin-bottom: 16px; }
.related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 14px; }
.related-card { border-radius: var(--radius); overflow: hidden; background: var(--white); box-shadow: var(--shadow); text-decoration: none; color: inherit; }
.related-card img { width: 100%; height: 120px; object-fit: cover; }
.related-card-body { padding: 8px 10px; }
.related-card-title { font-family: 'Instrument Serif', serif; font-size: 0.85rem; }
.related-card-meta { font-size: 0.72rem; color: var(--text-light); margin-top: 4px; }
.star-picker { display: flex; gap: 4px; margin-bottom: 10px; }
.star { font-size: 1.8rem; color: var(--border); cursor: pointer; transition: color 0.15s; }
.star.active, .star:hover { color: var(--gold); }
.review-item { border-bottom: 1px solid var(--border-light); padding: 14px 0; }
.review-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
.review-author { font-weight: 600; font-size: 0.88rem; }
.review-stars { color: var(--gold); font-size: 0.85rem; }
.review-text { font-size: 0.88rem; color: var(--text-light); line-height: 1.5; }
.review-date { font-size: 0.72rem; color: var(--text-lighter); margin-top: 4px; }
.made-item { display: flex; align-items: center; gap: 10px; padding: 10px 0; border-bottom: 1px solid var(--border-light); }
.made-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--gold); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.8rem; flex-shrink: 0; }
.made-info { font-size: 0.85rem; }
.made-name { font-weight: 600; }
.made-note { color: var(--text-light); }
.made-form { margin-bottom: 16px; }
</style>

<script>
// === RELATED RECIPES ===
(async function() {
  const grid = document.getElementById("related-grid");
  if (!grid) return;
  const recipeId = document.getElementById("save-btn")?.dataset.recipeId || "0";
  try {
    const res = await fetch("/api/related?id=" + recipeId + "&category=" + encodeURIComponent(document.querySelector("[data-category]")?.dataset.category || "comfort") + "&cuisine=" + encodeURIComponent(document.querySelector("[data-cuisine]")?.dataset.cuisine || ""));
    const data = await res.json();
    grid.innerHTML = data.recipes.map(function(r) {
      return '<a href="/recipe/' + r.slug + '" class="related-card"><img src="' + (r.hero_image || "") + '" alt="' + r.title + '" loading="lazy" /><div class="related-card-body"><div class="related-card-title">' + r.title + '</div><div class="related-card-meta">' + r.total_time + ' min</div></div></a>';
    }).join("");
  } catch(e) {}
})();

// === REVIEWS ===
let selectedRating = 0;
document.querySelectorAll("#star-picker .star").forEach(function(star) {
  star.addEventListener("click", function() {
    selectedRating = parseInt(this.dataset.val || "0");
    document.querySelectorAll("#star-picker .star").forEach(function(s, i) {
      s.classList.toggle("active", i < selectedRating);
    });
  });
  star.addEventListener("mouseenter", function() {
    const v = parseInt(this.dataset.val || "0");
    document.querySelectorAll("#star-picker .star").forEach(function(s, i) {
      s.style.color = i < v ? "var(--gold)" : "var(--border)";
    });
  });
});
document.getElementById("star-picker")?.addEventListener("mouseleave", function() {
  document.querySelectorAll("#star-picker .star").forEach(function(s, i) {
    s.style.color = i < selectedRating ? "var(--gold)" : "var(--border)";
  });
});

document.getElementById("submit-review")?.addEventListener("click", async function() {
  if (!localStorage.getItem("db_user")) { window.location.href = "/login"; return; }
  if (!selectedRating) { alert("Please select a rating"); return; }
  const recipeId = document.getElementById("save-btn")?.dataset.recipeId || "0";
  const comment = (document.getElementById("review-text") as HTMLTextAreaElement).value;
  const btn = this as HTMLButtonElement;
  btn.disabled = true; btn.textContent = "Submitting...";
  try {
    await fetch("/api/reviews", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ recipe_id: parseInt(recipeId), rating: selectedRating, comment }),
    });
    btn.textContent = "Review submitted!";
    loadReviews();
  } catch(e) { btn.textContent = "Submit review"; btn.disabled = false; }
});

async function loadReviews() {
  const list = document.getElementById("reviews-list");
  if (!list) return;
  const recipeId = document.getElementById("save-btn")?.dataset.recipeId || "0";
  try {
    const res = await fetch("/api/reviews?recipe_id=" + recipeId);
    const data = await res.json();
    list.innerHTML = data.reviews.map(function(r) {
      const stars = "&#9733;".repeat(r.rating) + "&#9734;".repeat(5 - r.rating);
      return '<div class="review-item"><div class="review-header"><span class="review-author">' + (r.display_name || "Anonymous") + '</span><span class="review-stars">' + stars + '</span></div>' + (r.comment ? '<p class="review-text">' + r.comment + '</p>' : '') + '</div>';
    }).join("");
  } catch(e) {}
}
loadReviews();

// === MADE THIS ===
document.getElementById("made-btn")?.addEventListener("click", async function() {
  if (!localStorage.getItem("db_user")) { window.location.href = "/login"; return; }
  const recipeId = document.getElementById("save-btn")?.dataset.recipeId || "0";
  const note = (document.getElementById("made-note") as HTMLInputElement).value;
  const btn = this as HTMLButtonElement;
  btn.disabled = true; btn.textContent = "Sharing...";
  try {
    await fetch("/api/made-this", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ recipe_id: parseInt(recipeId), note }),
    });
    btn.textContent = "Shared!";
    loadMadeThis();
  } catch(e) { btn.textContent = "Share that I made this"; btn.disabled = false; }
});

async function loadMadeThis() {
  const list = document.getElementById("made-list");
  if (!list) return;
  const recipeId = document.getElementById("save-btn")?.dataset.recipeId || "0";
  try {
    const res = await fetch("/api/made-this?recipe_id=" + recipeId);
    const data = await res.json();
    list.innerHTML = data.entries.map(function(m) {
      const initial = (m.display_name || "?")[0].toUpperCase();
      return '<div class="made-item"><div class="made-avatar">' + initial + '</div><div class="made-info"><span class="made-name">' + (m.display_name || "Anonymous") + '</span> <span class="made-note">' + (m.note || "made this!") + '</span></div></div>';
    }).join("");
  } catch(e) {}
}
loadMadeThis();
</script>

      
      <!-- COOK MODE OVERLAY -->
      <div id="cook-mode" style="display:none">
        <div class="cm-overlay">
          <div class="cm-header">
            <span class="cm-title" id="cm-recipe-title">{recipe.title}</span>
            <button class="cm-close" onclick="exitCookMode()">&#10005;</button>
          </div>
          <div class="cm-body">
            <div class="cm-step-num" id="cm-step-num">1</div>
            <div class="cm-step-title" id="cm-step-title"></div>
            <div class="cm-step-text" id="cm-step-text"></div>
            <div class="cm-timer-wrap" id="cm-timer-wrap" style="display:none">
              <span class="cm-timer" id="cm-timer">0:00</span>
              <button class="cm-timer-btn" id="cm-timer-btn" onclick="toggleTimer()">Start timer</button>
            </div>
          </div>
          <div class="cm-footer">
            <button class="cm-nav" id="cm-prev" onclick="prevStep()">&#8592; Previous</button>
            <span class="cm-progress" id="cm-progress">1 / 5</span>
            <button class="cm-nav cm-nav-next" id="cm-next" onclick="nextStep()">Next &#8594;</button>
          </div>
        </div>
      </div>

      <!-- SHOPPING LIST MODAL -->
      <div id="shopping-modal" style="display:none">
        <div class="sl-overlay" onclick="document.getElementById('shopping-modal').style.display='none'"></div>
        <div class="sl-card">
          <div class="sl-header">
            <h3>&#128722; Shopping List</h3>
            <button onclick="document.getElementById('shopping-modal').style.display='none'" style="background:none;border:none;font-size:1.2rem;cursor:pointer">&#10005;</button>
          </div>
          <div id="sl-content">Loading...</div>
          <div class="sl-actions">
            <button class="sl-copy-btn" onclick="copyShoppingList()">Copy to clipboard</button>
          </div>
        </div>
      </div>

<style>
.cm-overlay { position:fixed;inset:0;background:#1a1a1a;z-index:9999;display:flex;flex-direction:column;color:#fff; }
.cm-header { display:flex;justify-content:space-between;align-items:center;padding:16px 24px;border-bottom:1px solid #333; }
.cm-title { font-family:'Instrument Serif',serif;font-size:1.1rem; }
.cm-close { background:none;border:none;color:#fff;font-size:1.4rem;cursor:pointer; }
.cm-body { flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 24px;text-align:center; }
.cm-step-num { font-size:4rem;font-weight:900;color:#D4A853;margin-bottom:12px; }
.cm-step-title { font-family:'Instrument Serif',serif;font-size:1.6rem;margin-bottom:16px; }
.cm-step-text { font-size:1.1rem;color:#ccc;line-height:1.7;max-width:600px; }
.cm-timer-wrap { margin-top:24px;display:flex;align-items:center;gap:12px; }
.cm-timer { font-size:2.4rem;font-weight:700;font-family:monospace;color:#D4A853; }
.cm-timer-btn { padding:8px 20px;border-radius:100px;border:1px solid #D4A853;background:transparent;color:#D4A853;font-weight:600;cursor:pointer; }
.cm-footer { display:flex;justify-content:space-between;align-items:center;padding:16px 24px;border-top:1px solid #333; }
.cm-nav { background:none;border:1px solid #555;color:#fff;padding:10px 24px;border-radius:100px;font-size:0.9rem;cursor:pointer; }
.cm-nav-next { background:#D4A853;border-color:#D4A853;font-weight:600; }
.cm-progress { color:#888;font-size:0.85rem; }

.sl-overlay { position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9998; }
.sl-card { position:fixed;bottom:0;left:0;right:0;background:#fff;border-radius:20px 20px 0 0;padding:24px;z-index:9999;max-height:70vh;overflow-y:auto; }
.sl-header { display:flex;justify-content:space-between;align-items:center;margin-bottom:16px; }
.sl-header h3 { font-size:1.2rem; }
.sl-category { font-weight:700;color:var(--gold-dark);font-size:0.85rem;margin-top:14px;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px; }
.sl-item { font-size:0.9rem;color:var(--text-light);padding:4px 0;display:flex;align-items:center;gap:8px; }
.sl-item input { accent-color: var(--gold); }
.sl-actions { margin-top:16px;text-align:center; }
.sl-copy-btn { padding:10px 24px;border-radius:100px;background:var(--gold);color:#fff;border:none;font-weight:600;cursor:pointer; }

@media print {
  nav, .ad-slot, .action-btn, footer, .cm-overlay, #shopping-modal, #adblock-modal, #join-banner, .pill, .save-btn, button { display:none !important; }
  .recipe-card, .masonry { display:none !important; }
  body { font-size:12pt; color:#000; background:#fff; }
  img { max-width:300px; }
  h1 { font-size:18pt; }
  h2 { font-size:14pt; margin-top:12pt; }
}
</style>

<script>
var cmSteps = [];
var cmCurrent = 0;
var cmTimerInterval = null;
var cmTimerSeconds = 0;
var cmTimerRunning = false;

try {
  cmSteps = JSON.parse(document.querySelector("[data-steps]")?.dataset.steps || "[]");
} catch(e) { cmSteps = []; }

function startCookMode() {
  if (!cmSteps.length) { alert("No steps found"); return; }
  cmCurrent = 0;
  document.getElementById("cook-mode").style.display = "block";
  document.body.style.overflow = "hidden";
  if ("wakeLock" in navigator) navigator.wakeLock.request("screen").catch(function(){});
  showStep();
}

function exitCookMode() {
  document.getElementById("cook-mode").style.display = "none";
  document.body.style.overflow = "";
  if (cmTimerInterval) clearInterval(cmTimerInterval);
  cmTimerRunning = false;
}

function showStep() {
  var s = cmSteps[cmCurrent];
  document.getElementById("cm-step-num").textContent = cmCurrent + 1;
  document.getElementById("cm-step-title").textContent = s.title || "Step " + (cmCurrent + 1);
  document.getElementById("cm-step-text").textContent = s.text || "";
  document.getElementById("cm-progress").textContent = (cmCurrent + 1) + " / " + cmSteps.length;
  document.getElementById("cm-prev").style.visibility = cmCurrent === 0 ? "hidden" : "visible";
  document.getElementById("cm-next").textContent = cmCurrent === cmSteps.length - 1 ? "Finish \u2713" : "Next \u2192";

  if (s.timer && s.timer > 0) {
    cmTimerSeconds = s.timer;
    document.getElementById("cm-timer-wrap").style.display = "flex";
    document.getElementById("cm-timer").textContent = formatTime(cmTimerSeconds);
    document.getElementById("cm-timer-btn").textContent = "Start timer";
    if (cmTimerInterval) clearInterval(cmTimerInterval);
    cmTimerRunning = false;
  } else {
    document.getElementById("cm-timer-wrap").style.display = "none";
  }
}

function nextStep() {
  if (cmCurrent < cmSteps.length - 1) { cmCurrent++; showStep(); }
  else exitCookMode();
}

function prevStep() {
  if (cmCurrent > 0) { cmCurrent--; showStep(); }
}

function toggleTimer() {
  if (cmTimerRunning) {
    clearInterval(cmTimerInterval);
    cmTimerRunning = false;
    document.getElementById("cm-timer-btn").textContent = "Resume";
  } else {
    cmTimerRunning = true;
    document.getElementById("cm-timer-btn").textContent = "Pause";
    cmTimerInterval = setInterval(function() {
      cmTimerSeconds--;
      document.getElementById("cm-timer").textContent = formatTime(cmTimerSeconds);
      if (cmTimerSeconds <= 0) {
        clearInterval(cmTimerInterval);
        cmTimerRunning = false;
        document.getElementById("cm-timer-btn").textContent = "Done!";
        try { new Audio("data:audio/wav;base64,UklGRnoGAABXQVZFZm10IBAAAAABAAEAQB8AAEAfAAABAAgAZGF0YQ==").play(); } catch(e) {}
      }
    }, 1000);
  }
}

function formatTime(s) {
  var m = Math.floor(s / 60);
  var sec = s % 60;
  return m + ":" + (sec < 10 ? "0" : "") + sec;
}

function printRecipe() { window.print(); }

async function addToShoppingList() {
  document.getElementById("shopping-modal").style.display = "block";
  var recipeId = document.getElementById("save-btn")?.dataset.recipeId || "0";
  try {
    var res = await fetch("/api/shopping-list", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ recipe_id: parseInt(recipeId), servings: 4 }),
    });
    var data = await res.json();
    if (data.error) {
      document.getElementById("sl-content").innerHTML = "<p>" + data.error + ". <a href='/login'>Log in</a> or just use the ingredient list above.</p>";
      return;
    }
    var html = "";
    Object.keys(data.categories).forEach(function(cat) {
      if (data.categories[cat].length === 0) return;
      html += "<div class='sl-category'>" + cat + "</div>";
      data.categories[cat].forEach(function(item) {
        html += "<div class='sl-item'><input type='checkbox' /><span>" + item + "</span></div>";
      });
    });
    document.getElementById("sl-content").innerHTML = html;
  } catch(e) {
    document.getElementById("sl-content").innerHTML = "<p>Could not generate list</p>";
  }
}

function copyShoppingList() {
  var items = document.querySelectorAll("#sl-content .sl-item span");
  var text = Array.from(items).map(function(s) { return "- " + s.textContent; }).join("\n");
  navigator.clipboard.writeText(text).then(function() {
    document.querySelector(".sl-copy-btn").textContent = "Copied!";
    setTimeout(function() { document.querySelector(".sl-copy-btn").textContent = "Copy to clipboard"; }, 2000);
  });
}

document.addEventListener("keydown", function(e) {
  if (document.getElementById("cook-mode").style.display !== "block") return;
  if (e.key === "ArrowRight") nextStep();
  if (e.key === "ArrowLeft") prevStep();
  if (e.key === "Escape") exitCookMode();
  if (e.key === " ") { e.preventDefault(); toggleTimer(); }
});
</script>

