---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import CategoryBar from '../../components/CategoryBar.astro';
import AdSlot from '../../components/AdSlot.astro';
import { env } from "cloudflare:workers";

const { slug } = Astro.params;
const db = env.DB;

const categoryNames = {
  "vegan": "Vegan", "keto": "Keto", "high-protein": "High Protein",
  "5-ingredient": "5 Ingredients", "15-min": "15 Minutes", "one-pot": "One Pot",
  "meal-prep": "Meal Prep", "comfort": "Comfort Food", "budget": "Broke Friendly",
  "date-night": "Date Night", "midnight": "Midnight Snack", "hangover": "Hangover Cure",
  "brain-food": "Brain Food", "post-workout": "Post Workout", "solo": "Cooking for One",
  "kids": "Kid Friendly", "diabetic": "Diabetic", "gluten-free": "Gluten Free",
  "no-cook": "No Cook", "quick": "Quick", "dessert": "Dessert",
  "heart-healthy": "Heart Healthy", "anti-inflammatory": "Anti-Inflammatory",
  "pcos": "PCOS Friendly", "pregnancy": "Pregnancy Safe",
};

const title = categoryNames[slug] || slug.replace(/-/g, " ").replace(/\b\w/g, l => l.toUpperCase());

let query = "SELECT * FROM recipes WHERE category = ? OR dietary LIKE ?";
const params = [slug, "%" + slug + "%"];

// Smart filters for special categories
if (slug === "15-min") {
  query = "SELECT * FROM recipes WHERE total_time <= 15";
} else if (slug === "5-ingredient") {
  query = "SELECT * FROM recipes WHERE LENGTH(ingredients) - LENGTH(REPLACE(ingredients, '\"item\"', '')) <= 30";
} else if (slug === "quick") {
  query = "SELECT * FROM recipes WHERE total_time <= 20 OR category = 'quick'";
} else if (slug === "one-pot") {
  query = "SELECT * FROM recipes WHERE category = 'one-pot' OR title LIKE '%One-Pot%' OR title LIKE '%One Pot%' OR title LIKE '%Skillet%' OR title LIKE '%Sheet Pan%'";
} else if (slug === "budget") {
  query = "SELECT * FROM recipes WHERE category = 'budget' OR title LIKE '%Budget%' OR title LIKE '%Cheap%' OR title LIKE '%Easy%Bean%' OR title LIKE '%Rice and Beans%' OR title LIKE '%Lentil%'";
} else if (slug === "high-protein") {
  query = "SELECT * FROM recipes WHERE protein >= 25 OR dietary LIKE '%high-protein%'";
} else if (slug === "gluten-free") {
  query = "SELECT * FROM recipes WHERE dietary LIKE '%gluten-free%' OR dietary LIKE '%Gluten%'";
} else if (slug === "midnight") {
  query = "SELECT * FROM recipes WHERE category = 'midnight' OR title LIKE '%Ramen%' OR title LIKE '%Midnight%' OR title LIKE '%Late%Night%'";
} else if (slug === "comfort") {
  query = "SELECT * FROM recipes WHERE category = 'comfort' OR title LIKE '%Soup%' OR title LIKE '%Stew%' OR title LIKE '%Casserole%' OR title LIKE '%Pot Pie%'";
} else if (slug === "no-cook") {
  query = "SELECT * FROM recipes WHERE cook_time = 0 OR category = 'no-cook' OR title LIKE '%No-Cook%' OR title LIKE '%No Cook%' OR title LIKE '%Smoothie%' OR title LIKE '%Salad%'";
} else if (slug === "kids") {
  query = "SELECT * FROM recipes WHERE category = 'kids' OR title LIKE '%Pancake%' OR title LIKE '%Mac and Cheese%' OR title LIKE '%Nugget%' OR title LIKE '%Pizza%'";
} else if (slug === "date-night") {
  query = "SELECT * FROM recipes WHERE category = 'date-night' OR title LIKE '%Steak%' OR title LIKE '%Lobster%' OR title LIKE '%Scallop%' OR title LIKE '%Chocolate%Lava%' OR title LIKE '%Creme Brulee%'";
} else if (slug === "hangover") {
  query = "SELECT * FROM recipes WHERE category = 'hangover' OR title LIKE '%Burrito%' OR title LIKE '%Ramen%' OR title LIKE '%Grilled Cheese%'";
} else if (slug === "post-workout") {
  query = "SELECT * FROM recipes WHERE category = 'post-workout' OR protein >= 30";
} else if (slug === "brain-food") {
  query = "SELECT * FROM recipes WHERE category = 'brain-food' OR title LIKE '%Salmon%' OR title LIKE '%Avocado%' OR title LIKE '%Smoothie Bowl%'";
} else if (slug === "solo") {
  query = "SELECT * FROM recipes WHERE category = 'solo' OR servings <= 2";
} else if (slug === "meal-prep") {
  query = "SELECT * FROM recipes WHERE category = 'meal-prep' OR title LIKE '%Meal Prep%' OR title LIKE '%Overnight%' OR title LIKE '%Bowl%'";
} else if (slug === "drinks") {
  query = "SELECT * FROM recipes WHERE category = 'drinks' OR title LIKE '%Mocktail%' OR title LIKE '%Latte%' OR title LIKE '%Smoothie%' OR title LIKE '%Mojito%' OR title LIKE '%Margarita%' OR title LIKE '%Spritz%' OR title LIKE '%Lemonade%' OR title LIKE '%Tea%'";
}

query += " ORDER BY CASE WHEN hero_image IS NOT NULL AND hero_image != '' THEN 0 ELSE 1 END, id DESC LIMIT 60";

const stmt = (slug === "15-min" || slug === "5-ingredient" || slug === "quick" || slug === "one-pot" || slug === "budget" || slug === "high-protein" || slug === "gluten-free" || slug === "midnight" || slug === "comfort" || slug === "no-cook" || slug === "kids" || slug === "date-night" || slug === "hangover" || slug === "post-workout" || slug === "brain-food" || slug === "solo" || slug === "meal-prep" || slug === "drinks")
  ? db.prepare(query)
  : db.prepare(query).bind(slug, "%" + slug + "%");

const { results: recipes } = await stmt.all();
---
<Base title={title + " Recipes | DishBloom"}>
  <Navbar />
  <CategoryBar />

  <section class="cat-hero">
    <div class="container">
      <h1 class="cat-title">{title} Recipes</h1>
      <p class="cat-count">{recipes.length} recipes</p>
    </div>
  </section>

  <AdSlot id="ad-category-top" size="leaderboard" />

  <div class="masonry">
    {recipes.map(r => {
      const img = r.hero_image || "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=600&q=80";
      const dietaryArr = (() => { try { return JSON.parse(r.dietary || "[]"); } catch(e) { return []; } })();
      const tag = dietaryArr[0] || r.category || "";
      return (
        <a href={"/recipe/" + r.slug} class="recipe-card">
          <img src={img} alt={r.title} loading="lazy" />
          <button class="save-btn" aria-label="Save">&#9829;</button>
          <div class="card-body">
            <div class="card-title">{r.title}</div>
            <div class="card-meta">
              <span>&#9733; {r.avg_rating || "4.5"}</span>
              <span class="dot">&middot;</span>
              <span>{r.total_time} min</span>
              <span class="dot">&middot;</span>
              <span>{r.calories} cal</span>
            </div>
            {tag && <div style="margin-top:8px"><span class="pill">{tag}</span></div>}
          </div>
        </a>
      );
    })}
  </div>

  {recipes.length === 0 && (
    <div class="empty-state">
      <h2>No recipes yet</h2>
      <p>We are cooking up {title.toLowerCase()} recipes. Check back soon!</p>
      <a href="/" class="back-btn">&larr; Browse all recipes</a>
    </div>
  )}
  <AdSlot id="ad-category-bottom" size="leaderboard" />
  <AdSlot id="ad-category-sticky" size="sticky" />
</Base>

<style>
.cat-hero { text-align: center; padding: 40px 0 24px; }
.cat-title { font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 6px; }
.cat-count { color: var(--text-light); font-size: 0.95rem; }
.empty-state { text-align: center; padding: 80px 20px; }
.empty-state h2 { font-size: 1.6rem; margin-bottom: 8px; }
.empty-state p { color: var(--text-light); margin-bottom: 20px; }
.back-btn { display: inline-block; padding: 10px 24px; border-radius: 100px; background: var(--gold); color: white; font-weight: 600; }
</style>
