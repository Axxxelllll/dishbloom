---
export const prerender = false;
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import { env } from "cloudflare:workers";

const db = env.DB;
const q = Astro.url.searchParams.get("q") || "";
let recipes = [];

if (q.trim()) {
  const search = "%" + q.trim() + "%";
  const { results } = await db.prepare(
    "SELECT * FROM recipes WHERE title LIKE ? OR description LIKE ? OR tags LIKE ? OR ingredients LIKE ? ORDER BY CASE WHEN hero_image IS NOT NULL AND hero_image != '' THEN 0 ELSE 1 END LIMIT 40"
  ).bind(search, search, search, search).all();
  recipes = results;
}
---
<Base title={(q ? q + " — " : "") + "Search | DishBloom"}>
  <Navbar />

  <section class="search-hero">
    <div class="container">
      <h1 class="search-title">{q ? "Results for \"" + q + "\"" : "Search recipes"}</h1>
      <form action="/search" method="get" class="search-form">
        <input type="text" name="q" value={q} placeholder="Search recipes, ingredients, cuisines..." class="search-input" autofocus />
        <button type="submit" class="search-submit">Search</button>
      </form>
      {q && <p class="search-count">{recipes.length} recipes found</p>}
    </div>
  </section>

  {recipes.length > 0 && (
    <div class="masonry">
      {recipes.map(r => {
        const img = r.hero_image || "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=600&q=80";
        const dietaryArr = (() => { try { return JSON.parse(r.dietary || "[]"); } catch(e) { return []; } })();
        const tag = dietaryArr[0] || r.category || "";
        return (
          <a href={"/recipe/" + r.slug} class="recipe-card">
            <img src={img} alt={r.title} loading="lazy" />
            <div class="card-body">
              <div class="card-title">{r.title}</div>
              <div class="card-meta">
                <span>&#9733; {r.avg_rating || "4.5"}</span>
                <span class="dot">&middot;</span>
                <span>{r.total_time} min</span>
                <span class="dot">&middot;</span>
                <span>{r.calories} cal</span>
              </div>
              {tag && <div style="margin-top:8px"><span class="pill">{tag}</span></div>}
            </div>
          </a>
        );
      })}
    </div>
  )}

  {q && recipes.length === 0 && (
    <div class="empty-state">
      <h2>No recipes found</h2>
      <p>Try searching for something else like "chicken", "pasta", or "vegan"</p>
    </div>
  )}
</Base>

<style>
.search-hero { text-align: center; padding: 48px 0 32px; }
.search-title { font-size: clamp(1.6rem, 4vw, 2.4rem); margin-bottom: 20px; }
.search-form { display: flex; max-width: 560px; margin: 0 auto 16px; gap: 8px; }
.search-input { flex: 1; padding: 14px 20px; border: 2px solid var(--border); border-radius: 100px; font-size: 1rem; outline: none; transition: border-color 0.2s; }
.search-input:focus { border-color: var(--gold); }
.search-submit { padding: 14px 28px; border-radius: 100px; border: none; background: var(--gold); color: white; font-weight: 600; font-size: 0.95rem; cursor: pointer; }
.search-submit:hover { background: var(--gold-dark); }
.search-count { color: var(--text-light); font-size: 0.9rem; }
.empty-state { text-align: center; padding: 60px 20px; }
.empty-state h2 { font-size: 1.4rem; margin-bottom: 8px; }
.empty-state p { color: var(--text-light); }
</style>
