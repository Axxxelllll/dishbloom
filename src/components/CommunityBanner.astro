---
---
<div class="top-banner">
  <div class="top-banner-inner">
    <span class="tb-text">🎉 <strong>Join free</strong> — Show off your culinary skills, take part in fun challenges & win prizes!</span>
    <a href="/signup" class="tb-btn">Sign up free →</a>
  </div>
</div>

<style>
.top-banner {
  background: linear-gradient(90deg, #D4A853, #E8B960, #F0C86E, #E8B960, #D4A853);
  background-size: 200% 100%;
  animation: shimmer 3s ease infinite;
  padding: 10px 20px;
  text-align: center;
}
@keyframes shimmer {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}
.top-banner-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
}
.tb-text {
  color: #fff;
  font-size: 0.88rem;
  line-height: 1.4;
}
.tb-text strong { font-weight: 700; }
.tb-btn {
  background: #fff;
  color: #B8903E;
  padding: 6px 18px;
  border-radius: 100px;
  font-size: 0.82rem;
  font-weight: 700;
  white-space: nowrap;
  transition: all 0.2s;
}
.tb-btn:hover { background: #1a1a1a; color: #fff; }
@media (max-width: 600px) {
  .tb-text { font-size: 0.78rem; }
  .tb-btn { font-size: 0.75rem; padding: 5px 14px; }
}
</style>
