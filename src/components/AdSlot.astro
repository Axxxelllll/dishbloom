---
interface Props {
  id: string;
  size?: "banner" | "rectangle" | "leaderboard" | "sticky";
}
const { id, size = "rectangle" } = Astro.props;
const sizeClass = "ad-" + size;
---
<div class={"ad-slot " + sizeClass} id={id} data-ad-slot={id}>
  <span class="ad-label">Advertisement</span>
</div>

<style>
.ad-slot {
  background: var(--bg);
  border: 1px dashed var(--border);
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin: 24px auto;
  max-width: 100%;
}
.ad-label {
  font-size: 0.7rem;
  color: var(--text-lighter);
  text-transform: uppercase;
  letter-spacing: 1px;
}
.ad-banner { width: 100%; height: 90px; }
.ad-rectangle { width: 100%; max-width: 336px; height: 280px; }
.ad-leaderboard { width: 100%; height: 90px; max-width: 728px; }
.ad-sticky {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60px;
  z-index: 90;
  border-radius: 0;
  border: none;
  border-top: 1px solid var(--border);
  background: var(--white);
  margin: 0;
}
@media (min-width: 768px) { .ad-sticky { display: none; } }
</style>
