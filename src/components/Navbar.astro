---
---
<nav class="navbar">
  <div class="nav-inner">
    <a href="/" class="logo">
      <span class="logo-icon">&#x1F33C;</span>
      <span class="logo-text">dish<span class="logo-gold">bloom</span></span>
    </a>
    
    <div class="nav-search">
      <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input type="text" placeholder="Search recipes, ingredients, cuisines..." onkeydown="if(event.key==='Enter'){window.location='/search?q='+encodeURIComponent(this.value)}" />
    </div>

    <div class="nav-links">
      <a href="/category/vegan" class="nav-link">Vegan</a>
      <a href="/category/keto" class="nav-link">Keto</a>
      <a href="/category/quick" class="nav-link">Quick</a>
      <a href="/category/meal-prep" class="nav-link">Meal Prep</a>
      <a href="/pantry" class="nav-link">What Can I Cook?</a>
      <a href="/drinks" class="nav-link">Drinks</a>
      <a href="/blog" class="nav-link">Blog</a>
      <a href="/stories" class="nav-link">Stories</a>
      <a href="#" class="nav-link nav-more">More &#9662;</a>
    </div>

    <div class="nav-actions">
      <a href="/community" class="nav-link">Community</a>
      <a href="/challenges" class="nav-link">Challenges</a>
      <a href="/saved" class="nav-link">Saved</a>
      <a href="/submit" class="nav-link">+ Recipe</a>
      <a href="/login" class="nav-btn nav-btn-outline">Log in</a>
      <a href="/signup" class="nav-btn nav-btn-gold">Sign up</a>
    </div>

    <button class="mobile-menu-btn" aria-label="Menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
    </button>
  </div>
</nav>

<style>
.navbar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border-light);
}
.nav-inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 16px;
  height: 64px;
  display: flex;
  align-items: center;
  gap: 16px;
}
.logo {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}
.logo-icon { font-size: 1.5rem; }
.logo-text {
  font-family: 'Instrument Serif', serif;
  font-size: 1.4rem;
  letter-spacing: -0.5px;
}
.logo-gold { color: var(--gold); }
.nav-search {
  flex: 1;
  max-width: 500px;
  position: relative;
}
.nav-search input {
  width: 100%;
  padding: 10px 16px 10px 42px;
  border: 1px solid var(--border);
  border-radius: 100px;
  font-size: 0.9rem;
  background: var(--bg);
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.nav-search input:focus {
  border-color: var(--gold);
  box-shadow: 0 0 0 3px var(--gold-light);
}
.search-icon {
  position: absolute;
  left: 14px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-lighter);
}
.nav-links {
  display: flex;
  gap: 4px;
}
.nav-link {
  padding: 6px 14px;
  border-radius: 100px;
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--text-light);
  transition: background 0.2s, color 0.2s;
}
.nav-link:hover {
  background: var(--gold-light);
  color: var(--gold-dark);
}
.nav-actions { display: flex; gap: 8px; flex-shrink: 0; }
.nav-btn {
  padding: 8px 18px;
  border-radius: 100px;
  font-size: 0.85rem;
  font-weight: 600;
  transition: all 0.2s;
}
.nav-btn-outline {
  border: 1px solid var(--border);
  color: var(--text);
}
.nav-btn-outline:hover { border-color: var(--gold); color: var(--gold-dark); }
.nav-btn-gold {
  background: var(--gold);
  color: white;
  border: none;
}
.nav-btn-gold:hover { background: var(--gold-dark); }
.mobile-menu-btn {
  display: none;
  background: none;
  border: none;
  color: var(--text);
}
@media (max-width: 768px) {
  .nav-links, .nav-actions { display: none; }
  .mobile-menu-btn { display: flex; }
  .nav-search { max-width: none; }
}
@media (max-width: 480px) {
  .nav-search input { font-size: 0.85rem; padding: 8px 12px 8px 38px; }
}
</style>
